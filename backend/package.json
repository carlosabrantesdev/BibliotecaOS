{
  "name": "biblioteca-api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts",
    "db:setup": "prisma db push && ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5",
    "bcryptjs": "^2",
    "cors": "^2",
    "express": "^4",
    "jsonwebtoken": "^9"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2",
    "@types/cors": "^2",
    "@types/express": "^4",
    "@types/jsonwebtoken": "^9",
    "@types/node": "^20",
    "prisma": "^5",
    "ts-node": "^10",
    "ts-node-dev": "^2",
    "typescript": "^5"
  }
}
