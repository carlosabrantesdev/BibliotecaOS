generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Usuario {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  senha     String
  role      String   @default("user")
  nome      String
  criadoEm DateTime @default(now()) @map("criado_em")

  @@map("usuarios")
}

model Livro {
  id         Int      @id @default(autoincrement())
  titulo     String
  autor      String
  disponivel Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  @@map("livros")
}
